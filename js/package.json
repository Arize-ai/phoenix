{
  "name": "phoenix-js",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Arize Phoenix Javascript Tooling",
  "keywords": [
    "evaluation",
    "llmops",
    "observability",
    "telemetry"
  ],
  "homepage": "https://github.com/Arize-ai/phoenix/tree/main/js",
  "bugs": {
    "url": "https://github.com/Arize-ai/phoenix/issues"
  },
  "license": "ELv2",
  "author": "oss@arize.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arize-ai/phoenix.git"
  },
  "scripts": {
    "build": "pnpm run -r build",
    "ci:publish": "pnpm run -r build && pnpm publish -r --access public --provenance",
    "ci:version": "pnpm changeset version",
    "clean": "pnpm run clean:node_modules",
    "clean:node_modules": "rimraf --glob '**/node_modules/**'",
    "docs:generate": "typedoc",
    "docs:preview": "rimraf docs && pnpm run docs:generate && pnpx http-server ./docs -p 8080 -o",
    "fmt": "oxfmt --config ../.oxfmtrc.jsonc",
    "fmt:check": "oxfmt --check --config ../.oxfmtrc.jsonc",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "sync-package-docs": "node ./scripts/sync-package-docs.mjs",
    "test": "pnpm run -r test",
    "typecheck": "pnpm run -r typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.53.0",
    "pkg-pr-new": "^0.0.39",
    "rimraf": "^6.1.3",
    "tsc-alias": "1.8.11",
    "typedoc": "^0.28.17",
    "typescript": "^6.0.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=10",
    "pnpm": ">=3"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
      "rollup@<4.59.0": ">=4.59.0",
      "ajv@<8.18.0": ">=8.18.0",
      "esbuild@<=0.24.2": ">=0.25.0",
      "hono@<4.12.18": ">=4.12.18",
      "@hono/node-server@<1.19.14": ">=1.19.14",
      "undici@<6.24.0": ">=6.24.0",
      "express-rate-limit@<8.3.0": ">=8.3.0",
      "vite@<8.0.10": ">=8.0.10",
      "protobufjs@<7.5.6": ">=7.5.6",
      "postcss@<8.5.14": ">=8.5.14",
      "langsmith@<0.6.1": ">=0.6.1",
      "yaml@<2.8.4": ">=2.8.4",
      "brace-expansion@>=1.0.0 <2.0.2": ">=2.0.2",
      "brace-expansion@>=2.0.0 <2.0.2": ">=2.0.2",
      "brace-expansion@>=3.0.0 <3.0.1": ">=3.0.1",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "uuid@>=11.0.0 <11.1.1": ">=11.1.1",
      "uuid@>=13.0.0 <13.0.1": ">=13.0.1",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "path-to-regexp@>=2.0.0 <3.3.0": ">=3.3.0",
      "path-to-regexp@>=4.0.0 <6.3.0": ">=6.3.0",
      "path-to-regexp@>=7.0.0 <8.4.2": ">=8.4.2",
      "picomatch@<2.3.2": ">=4.0.4",
      "picomatch@>=3.0.0 <4.0.4": ">=4.0.4",
      "ip-address@<10.1.1": ">=10.1.1"
    }
  }
}
