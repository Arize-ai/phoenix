{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    // Examples run via tsx, which loads ESM-only packages (ai, @ai-sdk/*)
    // transparently — typecheck them the same way instead of as CJS.
    "module": "esnext",
    "moduleResolution": "bundler"
  },
  "include": ["./**/*.ts", "../src/**/*.ts"],
  // The vitest examples run through vitest's own transform pipeline.
  "exclude": ["./vitest/**"]
}
