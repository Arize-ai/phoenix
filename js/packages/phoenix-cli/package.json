{
  "name": "@arizeai/phoenix-cli",
  "version": "1.11.1",
  "description": "A command-line interface for Phoenix",
  "keywords": [
    "arize",
    "cli",
    "llmops",
    "phoenix"
  ],
  "homepage": "https://github.com/Arize-ai/phoenix/tree/main/js/packages/phoenix-cli",
  "bugs": {
    "url": "https://github.com/Arize-ai/phoenix/issues"
  },
  "license": "Apache-2.0",
  "author": "oss@arize.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arize-ai/phoenix.git"
  },
  "bin": {
    "phoenix-cli": "build/index.js",
    "px": "build/index.js",
    "pxi": "build/pxi/index.js"
  },
  "files": [
    "build",
    "package.json"
  ],
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "pnpm run build:schema && tsc && tsc-alias && chmod 755 build/index.js build/pxi/index.js",
    "build:schema": "tsx scripts/build-schema.ts && cd ../../.. && js/node_modules/.bin/oxfmt --config .oxfmtrc.jsonc schemas/phoenix-cli-settings.json",
    "clean": "rimraf build",
    "dev": "tsx src/index.ts",
    "dev:pxi": "tsx src/pxi/index.tsx",
    "prebuild": "pnpm run clean",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@arizeai/openinference-semantic-conventions": "^2.5.0",
    "@arizeai/phoenix-client": "workspace:*",
    "@arizeai/phoenix-config": "workspace:*",
    "@clack/prompts": "^1.7.0",
    "ai": "^7.0.0",
    "commander": "^15.0.0",
    "cross-spawn": "^7.0.6",
    "ignore": "^7.0.6",
    "ink": "^7.1.1",
    "marked": "^18.0.6",
    "marked-terminal": "^7.3.0",
    "react": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arizeai/phoenix-testing": "workspace:*",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "ink-testing-library": "^4.0.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
