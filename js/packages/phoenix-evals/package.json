{
  "name": "@arizeai/phoenix-evals",
  "version": "2.0.0",
  "description": "A library for running evaluations for AI use cases",
  "keywords": [
    "arize",
    "evals",
    "evaluation",
    "llm",
    "phoenix"
  ],
  "homepage": "https://github.com/Arize-ai/phoenix/tree/main/js/packages/phoenix-evals",
  "bugs": {
    "url": "https://github.com/Arize-ai/phoenix/issues"
  },
  "license": "Apache-2.0",
  "author": "oss@arize.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arize-ai/phoenix.git"
  },
  "directories": {
    "doc": "./docs"
  },
  "files": [
    "dist",
    "docs",
    "src",
    "package.json"
  ],
  "main": "dist/src/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/src/index.js"
    },
    "./llm/*": {
      "import": "./dist/esm/llm/*.js",
      "require": "./dist/src/llm/*.js"
    },
    "./code": {
      "import": "./dist/esm/code/index.js",
      "require": "./dist/src/code/index.js"
    },
    "./code/*": {
      "import": "./dist/esm/code/*.js",
      "require": "./dist/src/code/*.js"
    },
    "./template/*": {
      "import": "./dist/esm/template/*.js",
      "require": "./dist/src/template/*.js"
    },
    "./templates/*": {
      "import": "./dist/esm/default_templates/*.js",
      "require": "./dist/src/default_templates/*.js"
    },
    "./types/*": {
      "import": "./dist/esm/types/*.d.ts",
      "require": "./dist/src/types/*.d.ts"
    },
    "./helpers/*": {
      "import": "./dist/esm/helpers/*.js",
      "require": "./dist/src/helpers/*.js"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.json tsconfig.esm.json && tsc-alias -p tsconfig.esm.json",
    "clean": "rimraf dist",
    "docs": "typedoc",
    "docs:preview": "pnpx http-server ./docs -p 8080 -o",
    "postbuild": "echo '{\"type\": \"module\"}' > ./dist/esm/package.json",
    "postpublish": "node ../../scripts/sync-package-docs.mjs clean phoenix-evals",
    "prebuild": "pnpm run clean",
    "prepack": "node ../../scripts/sync-package-docs.mjs phoenix-evals",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/otel": "^1.0.0",
    "@arizeai/openinference-core": "^2.4.0",
    "@opentelemetry/api": "^1.9.1",
    "ai": "^7.0.0",
    "jsonpath-plus": "^10.4.0",
    "mustache": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-sdk/google": "^4.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "@arizeai/openinference-instrumentation-openai": "^4.1.5",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@types/mustache": "^4.2.6",
    "@types/node": "^26.1.1",
    "msw": "^2.15.0",
    "nock": "^14.0.16",
    "tsx": "^4.23.1",
    "typedoc": "^0.28.20",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.12"
  }
}
