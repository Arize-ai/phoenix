{
  "name": "cli-agent-starter-kit",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "bin": {
    "cli-agent": "./dist/cli.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "pnpm phoenix:ensure && tsx --env-file=.env src/cli.ts",
    "dev:no-phoenix": "tsx --env-file=.env src/cli.ts",
    "dev:verbose": "pnpm phoenix:ensure && VERBOSE=true tsx --env-file=.env src/cli.ts",
    "eval": "vitest run --config vitest.config.ts",
    "eval:offline": "PHOENIX_TEST_TRACKING=false vitest run --config vitest.config.ts",
    "eval:watch": "vitest --config vitest.config.ts",
    "eval:task": "vitest run --config vitest.config.ts experiments",
    "eval:benchmark": "vitest run --config vitest.config.ts benchmark",
    "phoenix:down": "docker compose down",
    "phoenix:ensure": "./scripts/ensure-phoenix.sh",
    "phoenix:ensure:verbose": "./scripts/ensure-phoenix.sh --verbose",
    "phoenix:logs": "docker compose logs -f phoenix",
    "phoenix:reload": "docker compose down && docker compose up -d phoenix",
    "phoenix:restart": "docker compose restart phoenix",
    "phoenix:start": "docker compose up -d phoenix",
    "phoenix:stop": "docker compose stop phoenix",
    "seed": "pnpm phoenix:ensure && tsx scripts/seed-traces.ts",
    "seed:topic": "pnpm phoenix:ensure && tsx scripts/seed-traces.ts --dataset phoenix-topic",
    "start": "node --env-file=.env dist/cli.js",
    "start:verbose": "VERBOSE=true node --env-file=.env dist/cli.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/anthropic-v5": "npm:@ai-sdk/anthropic@3.0.81",
    "@ai-sdk/mcp": "^1.0.53",
    "@arizeai/openinference-core": "^2.4.0",
    "@arizeai/phoenix-client": "workspace:*",
    "@arizeai/phoenix-evals": "workspace:*",
    "@arizeai/phoenix-otel": "workspace:*",
    "@clack/prompts": "^1.6.0",
    "ai": "^6.0.211",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.4",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
