# Copy to .env and fill in. The eval suite loads this via dotenv/config.

# Anthropic API key — used by both the support bot (Haiku) and the LLM judge (Sonnet).
ANTHROPIC_API_KEY=sk-ant-...

# Phoenix collector endpoint. Defaults to http://localhost:6006 if unset.
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# API key for a Phoenix instance that requires auth (e.g. Phoenix Cloud). Omit for local.
# PHOENIX_API_KEY=

# Set to false to run the suite without recording anything to Phoenix.
# PHOENIX_TEST_TRACKING=false
