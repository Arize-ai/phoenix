    "@arizeai/phoenix-client": "workspace:*",
    "@arizeai/phoenix-evals": "workspace:*",
    "@arizeai/phoenix-otel": "workspace:*",
    "ai": "^6.0.230",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
