# Copy to `.env` and fill in to sync evals to a real Phoenix instance.
# Without these, `pnpm eval` runs in dry-run mode (no server needed).

# Phoenix endpoint (use https:// for any non-localhost host).
PHOENIX_HOST=http://localhost:6006
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# Bearer token, if your Phoenix requires auth.
# PHOENIX_API_KEY=

# Optional: override the OTel project name traces land in.
# PHOENIX_PROJECT_NAME=phoenix-test-quickstart

# Set to disable all syncing for a run (the default `pnpm eval` does this).
# PHOENIX_TEST_TRACKING=false

# Default repetition count per test (per-test / per-suite config overrides it).
# PHOENIX_TEST_REPETITIONS=1

# Only needed for evals/07-llm-openai.eval.ts (otherwise that suite is skipped).
# OPENAI_API_KEY=sk-...
