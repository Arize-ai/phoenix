# Copy to `.env` and fill in.
#
# These benchmarks measure the built-in @arizeai/phoenix-evals evaluators, all
# of which make a live LLM call, so OPENAI_API_KEY is REQUIRED — every suite is
# skipped without it. PHOENIX_* are only needed when syncing results to a real
# Phoenix instance (`pnpm eval:phoenix`).

# Required: the model behind every evaluator under test.
OPENAI_API_KEY=sk-...

# Phoenix endpoint (use https:// for any non-localhost host).
PHOENIX_HOST=http://localhost:6006
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# Bearer token, if your Phoenix requires auth.
# PHOENIX_API_KEY=

# Set to disable all syncing for a run (the default `pnpm eval` does this).
# PHOENIX_TEST_TRACKING=false
