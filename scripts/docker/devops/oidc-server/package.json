{
  "name": "phoenix-oidc-dev-server",
  "version": "1.0.0",
  "description": "Lightweight OIDC server for Phoenix development testing",
  "license": "MIT",
  "author": "Phoenix Dev Team",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm run fmt:check && pnpm run lint",
    "check:all": "pnpm run check && cd frontend && pnpm run check",
    "dev": "tsx watch src/server.ts",
    "fix": "pnpm run fmt && pnpm run lint:fix",
    "fix:all": "pnpm run fix && cd frontend && pnpm run fix",
    "fmt": "oxfmt --config ../../../../.oxfmtrc.jsonc",
    "fmt:check": "oxfmt --check --config ../../../../.oxfmtrc.jsonc",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^9.3.0",
    "fastify": "^5.10.0",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "oxfmt": "^0.58.0",
    "oxlint": "~1.73.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.11.0"
}
