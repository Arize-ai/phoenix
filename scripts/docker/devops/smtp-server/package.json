{
  "name": "phoenix-smtp-dev-server",
  "version": "1.0.0",
  "description": "Development SMTP server for Phoenix with React UI",
  "keywords": [
    "development",
    "email",
    "phoenix",
    "smtp"
  ],
  "license": "MIT",
  "author": "Phoenix Dev Team",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && pnpm run build:ui",
    "build:ui": "cd ui && pnpm run build",
    "dev": "tsx watch src/server.ts",
    "dev:ui": "cd ui && pnpm run dev",
    "fmt": "oxfmt --config ../../../../.oxfmtrc.jsonc",
    "fmt:check": "oxfmt --check --config ../../../../.oxfmtrc.jsonc",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/static": "^9.3.0",
    "fastify": "^5.10.0",
    "mailparser": "^3.9.14",
    "smtp-server": "^3.19.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.1.1",
    "@types/smtp-server": "^3.5.13",
    "oxfmt": "^0.58.0",
    "oxlint": "~1.73.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.11.0"
}
